{
  "name": "mind-expander-viewer",
  "version": "0.1.0",
  "private": true,
  "description": "Browser viewer for mind-expander facts JSON. D3 + SVG, TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.5"
  }
}
