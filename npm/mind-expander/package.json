{
  "name": "mind-expander",
  "version": "0.1.1",
  "description": "A human-AI collaboration tool for large codebases.",
  "license": "Apache-2.0",
  "author": "Bill Ming <mbbill@gmail.com>",
  "homepage": "https://github.com/mbbill/mind-expander",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbbill/mind-expander.git"
  },
  "bugs": {
    "url": "https://github.com/mbbill/mind-expander/issues"
  },
  "keywords": [
    "ai",
    "codebase",
    "visualization",
    "code-review",
    "architecture",
    "diagram",
    "tour",
    "rust",
    "typescript"
  ],
  "bin": {
    "mind-expander": "bin/mind-expander.js"
  },
  "scripts": {
    "prepack": "node -e \"const fs=require('fs');fs.mkdirSync('skill',{recursive:true});fs.copyFileSync('../../skill/mind-expander.md','skill/mind-expander.md')\""
  },
  "files": [
    "bin",
    "skill"
  ],
  "engines": {
    "node": ">=18"
  },
  "optionalDependencies": {
    "@mind-expander/binary-darwin-arm64": "0.1.1",
    "@mind-expander/binary-darwin-x64": "0.1.1",
    "@mind-expander/binary-linux-x64-gnu": "0.1.1",
    "@mind-expander/binary-linux-arm64-gnu": "0.1.1",
    "@mind-expander/binary-win32-x64-msvc": "0.1.1"
  }
}
